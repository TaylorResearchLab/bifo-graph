    "C1416558  # KCNC3 [n_cases=1] gene", "C1415743  # HSD3B2 [n_cases=1] gene", "C0812271  # MECOM [n_cases=1] gene", "C1428820  # WDR35 [n_cases=1] gene", "C0812304  # GLI1 [n_cases=1] gene",
    "C1415195  # GPC3 [n_cases=1] gene", "C1538489  # NSUN2 [n_cases=1] gene", "C1427622  # AHI1 [n_cases=1] gene", "C1422123  # PLVAP [n_cases=1] gene", "C1539530  # FREM1 [n_cases=1] gene",
    "C1425753  # DNAI2 [n_cases=1] gene", "C1413569  # COL10A1 [n_cases=1] gene", "C0812267  # ERBB4 [n_cases=1] gene", "C1419385  # RHO [n_cases=1] gene", "C1418426  # PDE6B [n_cases=1] gene",
    "C1418534  # PHKB [n_cases=1] gene", "C1421350  # ULK1 [n_cases=1] gene", "C1414327  # EIF2B1 [n_cases=1] gene", "C1425956  # TRIM46 [n_cases=1] gene", "C1824563  # CCDC39 [n_cases=1] gene",
    "C1421401  # USP24 [n_cases=1] gene"
] AS gene_names
MATCH (c:Concept)-[:PREF_TERM]->(t:Term)
WHERE t.name IN gene_names
WITH collect(DISTINCT c) AS seed_concepts

UNWIND seed_concepts AS seed
MATCH (seed)-[r]-(hop1:Concept)
WHERE type(r) <> 'CODE'
  AND type(r) <> 'STY'
  AND type(r) <> 'ISA'
  AND type(r) <> 'PREF_TERM'

WITH collect(DISTINCT seed) + collect(DISTINCT hop1) AS all_concepts
UNWIND all_concepts AS c
WITH DISTINCT c

OPTIONAL MATCH (c)-[:CODE]->(code:Code)
WITH c, code
ORDER BY
  CASE code.SAB
    WHEN 'HGNC'     THEN 0
    WHEN 'NCBIGENE' THEN 1
    WHEN 'MSIGDB'   THEN 2
    WHEN 'REACTOME' THEN 3
    WHEN 'GO'       THEN 4
    WHEN 'MONDO'    THEN 5
    WHEN 'OMIM'     THEN 6
    ELSE 99
  END ASC
WITH c, collect(code)[0] AS best_code
OPTIONAL MATCH (c)-[:PREF_TERM]->(pt:Term)

RETURN
    c.CUI                              AS node_id,
    'Concept'                          AS label,
    coalesce(pt.name, c.CUI)           AS name,
    coalesce(best_code.SAB, 'UNKNOWN') AS sab
ORDER BY node_id;

