    "C1415195  # GPC3 [n_cases=1] gene", "C1538489  # NSUN2 [n_cases=1] gene", "C1427622  # AHI1 [n_cases=1] gene", "C1422123  # PLVAP [n_cases=1] gene", "C1539530  # FREM1 [n_cases=1] gene",
    "C1425753  # DNAI2 [n_cases=1] gene", "C1413569  # COL10A1 [n_cases=1] gene", "C0812267  # ERBB4 [n_cases=1] gene", "C1419385  # RHO [n_cases=1] gene", "C1418426  # PDE6B [n_cases=1] gene",
    "C1418534  # PHKB [n_cases=1] gene", "C1421350  # ULK1 [n_cases=1] gene", "C1414327  # EIF2B1 [n_cases=1] gene", "C1425956  # TRIM46 [n_cases=1] gene", "C1824563  # CCDC39 [n_cases=1] gene",
    "C1421401  # USP24 [n_cases=1] gene"
] AS gene_names
MATCH (c:Concept)-[:PREF_TERM]->(t:Term)
WHERE t.name IN gene_names
WITH collect(DISTINCT c) AS seed_concepts

UNWIND seed_concepts AS seed
MATCH (seed)-[r]-(neighbor:Concept)
WHERE type(r) <> 'CODE'
  AND type(r) <> 'STY'
  AND type(r) <> 'ISA'
  AND type(r) <> 'PREF_TERM'
RETURN DISTINCT
    seed.CUI     AS source,
    neighbor.CUI AS target,
    type(r)      AS predicate
ORDER BY source, predicate, target;

